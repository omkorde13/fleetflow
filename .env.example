# ─── App ───────────────────────────────────────────
APP_NAME=FleetFlow
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80

# ─── Database ──────────────────────────────────────
POSTGRES_DB=fleetflow
POSTGRES_USER=fleetflow
POSTGRES_PASSWORD=fleetflow_secret
DATABASE_URL=postgresql+asyncpg://fleetflow:fleetflow_secret@postgres:5432/fleetflow

# ─── Redis ─────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@redis:6379/0
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_secret@redis:6379/2

# ─── JWT ───────────────────────────────────────────
JWT_SECRET_KEY=jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Google OAuth ──────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── Frontend (used to redirect back after OAuth) ──
FRONTEND_URL=http://localhost:3000

# ─── Razorpay ──────────────────────────────────────
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ─── Email (SMTP) ──────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@fleetflow.com

# ─── Weather API ───────────────────────────────────
OPENWEATHER_API_KEY=your-openweather-api-key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# ─── Pricing ───────────────────────────────────────
BASE_FARE=50.0
PRICE_PER_KM=10.0
SURGE_MULTIPLIER=1.5

# ─── Rate Limiting ─────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
